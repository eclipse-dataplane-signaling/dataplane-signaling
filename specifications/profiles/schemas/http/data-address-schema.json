{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://w3id.org/dspace-sig/profile/http/data-address-schema.json",
  "title": "HTTP Profile DataAddress",
  "description": "DataAddress for the HTTP Transfer Profile (https://w3id.org/dspace-sig/profile/http). Extends the base DSP DataAddress schema.",
  "allOf": [
    {
      "$ref": "https://w3id.org/dspace/2025/1/transfer/data-address-schema.json"
    }
  ],
  "properties": {
    "endpointType": {
      "type": "string",
      "description": "Identifies the transfer direction using the -push or -pull moniker.",
      "enum": [
        "https://w3id.org/dspace-sig/profile/http-push",
        "https://w3id.org/dspace-sig/profile/http-pull"
      ]
    },
    "endpoint": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://",
      "description": "A valid HTTP URL using the HTTPS scheme.",
      "examples": ["https://provider.example.com/data/asset-123"]
    },
    "endpointProperties": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "enum": ["authorization", "authType", "contentType"]
          },
          "value": {
            "type": "string"
          }
        },
        "required": ["name", "value"]
      }
    }
  },
  "required": ["endpointType", "endpoint"]
}
